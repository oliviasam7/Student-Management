<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Score_Range</fullName>
    <active>true</active>
    <description>Score must be between 0 and 100</description>
    <errorConditionFormula>Score__c &lt; 0 || Score__c &gt; 100</errorConditionFormula>
    <errorMessage>Score must be between 0 and 100.</errorMessage>
</ValidationRule>
